# Notification Configuration
ENABLE_EMAIL_NOTIFICATIONS=false
# EMAIL_SERVICE=your_email_service
# EMAIL_USER=your_email_username
# EMAIL_PASSWORD=your_email_password

# Analytics Configuration
ENABLE_ANALYTICS=false
